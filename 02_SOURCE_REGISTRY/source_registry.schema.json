{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asperitas.internal/schemas/source_registry.schema.json",
  "title": "Asperitas Source Registry Contract v11.1",
  "description": "JSON Schema contract for source registry entries. This schema governs approved-only source handling; it is not evidence that any source has been legally reviewed, ingested, embedded, indexed, or deployed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_name",
    "generated_at",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v11.1"
    },
    "registry_name": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_registry_entry"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "source_registry_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "title",
        "path_or_url",
        "priority",
        "source_type",
        "confidentiality",
        "license_status",
        "collection_status",
        "verification_status",
        "registry_status",
        "owner",
        "updated_at",
        "allowed_use",
        "compliance_tags",
        "evidence_span_policy",
        "decision_implication",
        "ingestion_allowed",
        "embedding_allowed",
        "kg_allowed",
        "external_output_allowed"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^[A-Z0-9][A-Z0-9_\\-]{2,80}$",
          "description": "Stable registry ID used in citations, eval fixtures, chunks, traces, and decision logs."
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "path_or_url": {
          "type": "string",
          "minLength": 1,
          "description": "Repository path, controlled storage path, official URL, DOI, patent URL, or other provenance pointer."
        },
        "priority": {
          "type": "string",
          "enum": [
            "P0_ACTIVE_CONSTITUTION",
            "P1_INTERNAL_COMPANY",
            "P2_PUBLIC_POSITIONING",
            "P3_SCIENCE_LITERATURE",
            "P4_REGULATORY_GOVERNMENT",
            "P5_MARKET_INDUSTRY",
            "P6_BENCHMARK_DOCTRINE"
          ]
        },
        "source_type": {
          "type": "string",
          "enum": [
            "prompt_constitution",
            "internal_strategy",
            "company_document",
            "public_website",
            "paper",
            "patent",
            "dataset",
            "government_regulatory",
            "conference_market",
            "benchmark_doctrine",
            "software_documentation",
            "other"
          ]
        },
        "confidentiality": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "confidential",
            "restricted"
          ]
        },
        "license_status": {
          "type": "string",
          "enum": [
            "unknown",
            "pending_review",
            "approved_internal_use",
            "approved_public_use",
            "restricted_use",
            "blocked"
          ]
        },
        "collection_status": {
          "type": "string",
          "enum": [
            "not_collected",
            "collected",
            "mounted",
            "text_extracted",
            "redacted",
            "chunked",
            "embedded",
            "indexed"
          ]
        },
        "verification_status": {
          "type": "string",
          "enum": [
            "unverified",
            "needs_review",
            "source_checked",
            "content_checked",
            "approved",
            "stale",
            "contradicted",
            "blocked"
          ]
        },
        "registry_status": {
          "type": "string",
          "enum": [
            "candidate",
            "needs_review",
            "approved",
            "ingested",
            "blocked",
            "archived"
          ],
          "description": "Only approved or ingested entries may be used for retrieval fixtures; ingested requires actual ingestion evidence."
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "updated_at": {
          "type": "string",
          "format": "date"
        },
        "allowed_use": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "governance_reference",
              "internal_rag",
              "eval_fixture",
              "citation",
              "kg_entity_extraction",
              "benchmark_analogy",
              "public_output",
              "training_or_finetuning",
              "blocked"
            ]
          }
        },
        "compliance_tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "none",
              "cites",
              "nagoya_abs",
              "lmo_gmo",
              "biosafety",
              "biosecurity",
              "ip_patent",
              "privacy_pii",
              "confidential_business",
              "export_control",
              "investor_public_claim",
              "legal_review_required",
              "human_approval_required"
            ]
          }
        },
        "evidence_span_policy": {
          "type": "string",
          "enum": [
            "required_exact_span",
            "required_section_span",
            "metadata_only",
            "not_allowed"
          ]
        },
        "decision_implication": {
          "type": "string",
          "minLength": 1,
          "description": "What this source can and cannot justify in decisions. Must not upgrade doctrine or benchmark analogy into implementation proof."
        },
        "ingestion_allowed": {
          "type": "boolean"
        },
        "embedding_allowed": {
          "type": "boolean"
        },
        "kg_allowed": {
          "type": "boolean"
        },
        "external_output_allowed": {
          "type": "boolean"
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "license_review_ref": {
              "type": "string"
            },
            "approval_ref": {
              "type": "string"
            },
            "ingestion_run_id": {
              "type": "string"
            },
            "eval_run_id": {
              "type": "string"
            },
            "decision_log_ref": {
              "type": "string"
            }
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "registry_status": {
                "const": "candidate"
              }
            },
            "required": [
              "registry_status"
            ]
          },
          "then": {
            "properties": {
              "ingestion_allowed": {
                "const": false
              },
              "embedding_allowed": {
                "const": false
              },
              "kg_allowed": {
                "const": false
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "license_status": {
                "enum": [
                  "unknown",
                  "pending_review",
                  "blocked"
                ]
              }
            },
            "required": [
              "license_status"
            ]
          },
          "then": {
            "properties": {
              "embedding_allowed": {
                "const": false
              },
              "external_output_allowed": {
                "const": false
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "registry_status": {
                "const": "ingested"
              }
            },
            "required": [
              "registry_status"
            ]
          },
          "then": {
            "required": [
              "evidence"
            ],
            "properties": {
              "evidence": {
                "required": [
                  "ingestion_run_id",
                  "decision_log_ref"
                ]
              }
            }
          }
        }
      ]
    }
  }
}
