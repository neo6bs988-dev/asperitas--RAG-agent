# =============================================================================
# Asperitas Git attribute policy
# =============================================================================
#
# Goals:
# - deterministic line endings across Windows, Linux, CI, and agent worktrees;
# - clean diffs for code, schemas, registries, and evidence files;
# - no accidental text conversion of Office, archive, model, or database files;
# - no implicit Git LFS dependency.
# =============================================================================


# -----------------------------------------------------------------------------
# Default text normalization
# -----------------------------------------------------------------------------

* text=auto eol=lf


# -----------------------------------------------------------------------------
# Source code and scripts
# -----------------------------------------------------------------------------

*.py      text eol=lf diff=python
*.pyi     text eol=lf diff=python
*.sh      text eol=lf
*.bash    text eol=lf
*.zsh     text eol=lf
*.ps1     text eol=lf
*.sql     text eol=lf

# Native Windows command files retain CRLF.
*.bat     text eol=crlf
*.cmd     text eol=crlf


# -----------------------------------------------------------------------------
# Documentation and repository governance
# -----------------------------------------------------------------------------

*.md      text eol=lf
*.mdx     text eol=lf
*.rst     text eol=lf
*.txt     text eol=lf
*.adoc    text eol=lf


# -----------------------------------------------------------------------------
# Configuration, schemas, registries, and structured evidence
# -----------------------------------------------------------------------------

*.toml    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.json    text eol=lf
*.jsonc   text eol=lf
*.jsonl   text eol=lf
*.csv     text eol=lf
*.tsv     text eol=lf
*.xml     text eol=lf
*.ini     text eol=lf
*.cfg     text eol=lf
*.conf    text eol=lf
*.properties text eol=lf
*.lock    text eol=lf
*.env.example text eol=lf
*.env.sample  text eol=lf
*.env.template text eol=lf


# -----------------------------------------------------------------------------
