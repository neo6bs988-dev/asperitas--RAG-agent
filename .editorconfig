# =============================================================================
# Asperitas cross-editor formatting baseline
# =============================================================================

root = true


# -----------------------------------------------------------------------------
# Repository-wide defaults
# -----------------------------------------------------------------------------

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2


# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------

[*.{py,pyi}]
indent_style = space
indent_size = 4
max_line_length = 120


# -----------------------------------------------------------------------------
# PowerShell
# -----------------------------------------------------------------------------

[*.ps1]
indent_style = space
indent_size = 4
end_of_line = lf


# -----------------------------------------------------------------------------
# POSIX shell
# -----------------------------------------------------------------------------

[*.{sh,bash,zsh}]
indent_style = space
indent_size = 2
end_of_line = lf


# -----------------------------------------------------------------------------
# Native Windows command files
# -----------------------------------------------------------------------------

[*.{bat,cmd}]
indent_style = space
indent_size = 2
end_of_line = crlf


# -----------------------------------------------------------------------------
# Structured configuration and schemas
# -----------------------------------------------------------------------------

[*.{json,jsonc,yaml,yml,toml,ini,cfg}]
indent_style = space
indent_size = 2
max_line_length = 120


# -----------------------------------------------------------------------------
# Markdown and long-form documentation
#
# Markdown trailing spaces may intentionally represent explicit line breaks.
# -----------------------------------------------------------------------------

[*.{md,mdx,rst,adoc}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
max_line_length = off


# -----------------------------------------------------------------------------
# Registry and line-oriented evidence formats
# -----------------------------------------------------------------------------

[*.{csv,tsv,jsonl}]
trim_trailing_whitespace = false
max_line_length = off


# -----------------------------------------------------------------------------
# Web files
# -----------------------------------------------------------------------------

[*.{html,css,scss,js,jsx,ts,tsx,svg}]
indent_style = space
indent_size = 2
max_line_length = 120


# -----------------------------------------------------------------------------
# XML
# -----------------------------------------------------------------------------

[*.xml]
indent_style = space
indent_size = 2
max_line_length = 120


# -----------------------------------------------------------------------------
# Makefiles require tabs
# -----------------------------------------------------------------------------

[{Makefile,makefile,GNUmakefile}]
indent_style = tab


# -----------------------------------------------------------------------------
# Patch and diff files preserve exact whitespace
# -----------------------------------------------------------------------------

[*.{patch,diff}]
trim_trailing_whitespace = false
insert_final_newline = false
